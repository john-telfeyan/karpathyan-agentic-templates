      // =============================
      "Bash(make *)",
      "PowerShell(make *)",
      "Cmd(make *)",

      "Bash(cmake *)",
      "PowerShell(cmake *)",
      "Cmd(cmake *)",

      "Bash(ninja *)",
      "PowerShell(ninja *)",
      "Cmd(ninja *)",

      // =============================
      // Linux utilities
      // =============================
      "Bash(ls *)",
      "PowerShell(ls *)",
      "Cmd(dir *)",

      "Bash(cat *)",
