      "Bash(which *)",
      "PowerShell(Get-Command *)",
      "Cmd(where *)",

      "Bash(pwd *)",
      "PowerShell(pwd)",
      "Cmd(cd)",

      // =============================
      // Windows package managers
      // =============================
      "PowerShell(winget *)",
      "Cmd(winget *)",

      "PowerShell(choco *)",
      "Cmd(choco *)",

      "PowerShell(scoop *)",
      "Cmd(scoop *)",

      // =============================
      // macOS package manager
      // =============================
      "Bash(brew *)"
    ],

    "ask": [
      "Bash(curl *)",
      "PowerShell(Invoke-WebRequest *)",
      "PowerShell(Invoke-RestMethod *)",
      "Cmd(curl *)",

      "Bash(wget *)",

      "Bash(unzip *)",
      "PowerShell(Expand-Archive *)",

      "Bash(tar *)",
      "PowerShell(tar *)",

      "Bash(mv *)",
      "PowerShell(Move-Item *)",
      "Cmd(move *)",

      "Bash(chmod *)",
      "PowerShell(icacls *)",

      "Bash(chown *)"
    ],

    "deny": [
      // History destruction
      "Bash(git reset --hard *)",
      "PowerShell(git reset --hard *)",
      "Cmd(git reset --hard *)",

      "Bash(git clean -fd *)",
      "PowerShell(git clean -fd *)",
      "Cmd(git clean -fd *)",

      "Bash(git clean -fdx *)",
      "PowerShell(git clean -fdx *)",
      "Cmd(git clean -fdx *)",

      // Dangerous deletes
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",

      "PowerShell(Remove-Item -Recurse -Force *)",

      "Cmd(rd /s *)",
      "Cmd(rmdir /s *)",

      "Bash(shred *)",

      // Disk formatting
      "Bash(mkfs *)",
      "PowerShell(Format-Volume *)",
      "Cmd(format *)",

      // Privilege escalation
      "Bash(sudo *)",
      "PowerShell(Start-Process * -Verb RunAs *)"
    ]
  }
}
