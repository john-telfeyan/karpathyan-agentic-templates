      "Cmd(npx *)",

      "Bash(pnpm *)",
      "PowerShell(pnpm *)",
      "Cmd(pnpm *)",

      "Bash(yarn *)",
      "PowerShell(yarn *)",
      "Cmd(yarn *)",

      // =============================
      // Python
      // =============================
      "Bash(python *)",
      "PowerShell(python *)",
      "Cmd(python *)",

      "Bash(py *)",
      "PowerShell(py *)",
      "Cmd(py *)",

      "Bash(pip *)",
      "PowerShell(pip *)",
      "Cmd(pip *)",

      "Bash(pip3 *)",
      "PowerShell(pip3 *)",
      "Cmd(pip3 *)",

      "Bash(pytest *)",
