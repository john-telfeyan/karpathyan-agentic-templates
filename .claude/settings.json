      "Bash(find *)",
      "PowerShell(Get-ChildItem *)",
      "Cmd(where *)",

      "Bash(grep *)",
      "PowerShell(Select-String *)",
      "Cmd(findstr *)",

      "Bash(rg *)",
      "PowerShell(rg *)",
      "Cmd(rg *)",

      "Bash(fd *)",
      "PowerShell(fd *)",
      "Cmd(fd *)",

      "Bash(tree *)",
      "PowerShell(tree *)",
