      // =============================
      "Bash(go *)",
      "PowerShell(go *)",
      "Cmd(go *)",

      // =============================
      // Java
      // =============================
      "Bash(gradle *)",
      "PowerShell(gradle *)",
      "Cmd(gradle *)",

      "Bash(./gradlew *)",
      "PowerShell(gradlew.bat *)",
      "Cmd(gradlew.bat *)",

      // =============================
      // Docker
      // =============================
      "Bash(docker *)",
      "PowerShell(docker *)",
      "Cmd(docker *)",

      "Bash(docker compose *)",
